# ─────────────────────────────────────────────────────────────────────────────
# Ritha Web — Production build environment
# Copy to .env.production and set values before running `npm run build`.
# Vite inlines these at build time; they are public (visible in the bundle).
# ─────────────────────────────────────────────────────────────────────────────

# Absolute URL of the Django API. Must NOT end in a trailing slash.
# Example: https://api.getritha.com/api
VITE_API_BASE_URL=https://api.getritha.com/api

# Absolute WebSocket base URL. Must include scheme (wss://) and host, no path.
# Example: wss://api.getritha.com
VITE_WS_BASE_URL=wss://api.getritha.com

# Optional: app version surfaced in the UI / sent with Sentry events.
VITE_APP_VERSION=1.0.0
