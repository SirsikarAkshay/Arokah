# ─────────────────────────────────────────────────────────────────────────────
# Arokah Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=arokah.settings_production
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=localhost,127.0.0.1,api.arokah.com
DEBUG=false

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=arokah
DB_USER=arokah
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=disable
# For managed databases (RDS, Cloud SQL), set DB_SSLMODE=require

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://arokah.com,https://app.arokah.com
WEB_APP_URL=https://app.arokah.com
MOBILE_APP_URL=arokah://
FRONTEND_URL=https://app.arokah.com

# ── AI (Mistral) ─────────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── Google Calendar OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.arokah.com/api/calendar/google/callback/

# ── Microsoft Outlook OAuth ──────────────────────────────────────────────���───
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.arokah.com/api/calendar/outlook/callback/

# ── Apple CalDAV ─────────────────────────────────────────────────────────────
APPLE_CALDAV_URL=https://caldav.icloud.com

# ── Firebase (Push Notifications) ────────────────────────────────────────────
# Path to the Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-credentials.json

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@arokah.com

# ── S3 Storage (optional — leave empty for local media) ─────────────────────
AWS_STORAGE_BUCKET_NAME=
AWS_REGION=eu-central-1
AWS_S3_CUSTOM_DOMAIN=

# ── Sentry (optional) ───────────────────────────────────────────────────────
SENTRY_DSN=
